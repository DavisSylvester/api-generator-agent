# ── LLM provider ───────────────────────────────────────────────────────────
# One of: ollama, openai, anthropic
LLM_PROVIDER=ollama

# Ollama (local or self-hosted)
OLLAMA_HOST=http://localhost:11434
# Optional cloud Ollama key (uses https://api.ollama.com for codegen + qa)
OLLAMA_API_KEY=

# OpenAI — required when LLM_PROVIDER=openai
OPENAI_API_KEY=

# Anthropic — required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ── LangSmith tracing (optional) ───────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=api-generator-agent

# ── Pipeline tuning ────────────────────────────────────────────────────────
MAX_FIX_ITERATIONS=20
MAX_CONCURRENCY=4
WORKSPACE_DIR=.workspace
LLM_TIMEOUT_MS=1800000
INTEGRATION_PORT=4100
TASK_COST_LIMIT=3.00

# ── Telegram notifications (optional) ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFICATION_INTERVAL_MS=300000

# ── Discord notifications (optional) ───────────────────────────────────────
# Live monitoring of pipeline runs. See docs/discord-integration-plan.md.
#
# Webhook transport requires a Discord FORUM CHANNEL (not a regular text
# channel) so thread-per-run can be created. If you need a regular text
# channel, switch DISCORD_TRANSPORT to "bot" (not yet implemented).
DISCORD_ENABLED=false
DISCORD_TRANSPORT=webhook

# Webhook mode (recommended):
DISCORD_PIPELINE_WEBHOOK_URL=
DISCORD_QA_TOOLS_WEBHOOK_URL=
DISCORD_ALERT_WEBHOOK_URL=

# Bot mode (mutually exclusive with webhook URLs above; reserved for future):
DISCORD_BOT_TOKEN=
DISCORD_PIPELINE_CHANNEL_ID=
DISCORD_QA_TOOLS_CHANNEL_ID=
DISCORD_ALERT_CHANNEL_ID=

# Common — who to ping on hard failures
# Examples: @here, <@USER_ID>, <@&ROLE_ID>
DISCORD_ALERT_MENTION=

# How long to coalesce rapid card edits (ms). 250 is a sensible default.
DISCORD_EDIT_WINDOW_MS=250
